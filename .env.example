## Server + Hardhat env (DO NOT COMMIT REAL SECRETS)
#
# Required for Sepolia deploys (leave blank for localhost testing)
# API_URL="https://eth-sepolia.g.alchemy.com/v2/REPLACE_ME"
# PRIVATE_KEY="0xREPLACE_WITH_SEPOLIA_FUNDED_PRIVATE_KEY"
#
# Used by the smart contract + front-end signature flow (must match client/.env)
SECRET_MESSAGE="carbon-credits-2026"
#
# Pinata keys are used by the local backend to upload/unpin PDFs to IPFS
# Create a key with scopes: pinFileToIPFS + unpin
# PINATA_API_KEY="REPLACE_ME"
# PINATA_SECRET_API_KEY="REPLACE_ME"
#
# Optional: override backend port (client expects 5001 by default via proxy)
# PORT=5001

